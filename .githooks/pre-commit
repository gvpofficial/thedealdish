#!/bin/sh
# Git pre-commit hook to verify documentation and terms sync.

# Define files to watch
CODE_FILES="index.html style.css app.js"
DOC_FILES="README.md"

CODE_CHANGED=false
DOC_CHANGED=false
LEGAL_CHANGED=false

# Get list of staged files
STAGED_FILES=$(git diff --cached --name-only)

for file in $STAGED_FILES; do
    # Check if a code file is staged
    for code_file in $CODE_FILES; do
        if [ "$file" = "$code_file" ]; then
            CODE_CHANGED=true
        fi
    done
    
    # Check if README.md is staged
    if [ "$file" = "README.md" ]; then
        DOC_CHANGED=true
    fi
done

# If app.js is changed, check if legal sections are modified
if [ "$CODE_CHANGED" = true ] && git diff --cached --name-only | grep -q "app.js"; then
    # Search for changes inside the openLegalModal function or legal texts in git diff
    if git diff --cached app.js | grep -E "\+(.*)(openLegalModal|Privacy Policy|Terms of Service|Cookie Settings|FSSAI Rules)" >/dev/null 2>&1; then
        LEGAL_CHANGED=true
    fi
fi

# Print warnings if code is changed but no documentation or legal terms were updated
if [ "$CODE_CHANGED" = true ] && [ "$DOC_CHANGED" = false ] && [ "$LEGAL_CHANGED" = false ]; then
    echo "======================================================================"
    echo "⚠️  WARNING: You updated index.html, style.css, or app.js,"
    echo "   but did not update README.md or the legal terms in app.js."
    echo ""
    echo "   Ensure that any new features, credentials, database structures,"
    echo "   or rules are documented in:"
    echo "   - README.md (Key Features, Credentials, etc.)"
    echo "   - app.js -> openLegalModal() (Privacy, Terms, Cookies, FSSAI)"
    echo "======================================================================"
fi
